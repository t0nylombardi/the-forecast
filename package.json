{
  "name": "app",
  "private": true,
  "devDependencies": {
    "esbuild": "^0.28.0",
    "postcss": "^8.5.12"
  },
  "scripts": {
    "build:css": "tailwindcss --postcss -i ./app/assets/tailwind/application.css -o ./app/assets/builds/application.css --watch --poll",
    "build": "esbuild app/javascript/application.js --bundle --sourcemap --outdir=app/assets/builds --watch"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@tailwindcss/postcss": "^4.2.4",
    "tailwindcss": "^4.2.4"
  }
}
