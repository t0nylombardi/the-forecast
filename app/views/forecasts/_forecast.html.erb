<div id="forecast" class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <% if forecast.present? && forecast["error"].blank? %>
    <div class="space-y-2">
      <p class="text-sm font-medium uppercase tracking-wide text-slate-500">Current Conditions</p>
      <h2 class="text-2xl font-semibold text-slate-900"><%= forecast.dig("location", "name") %></h2>
      <p class="text-slate-600"><%= forecast.dig("location", "region") %></p>
      <p class="text-4xl font-bold text-slate-900"><%= forecast.dig("current", "temp_f") %>F</p>
      <p class="text-slate-700"><%= forecast.dig("current", "condition", "text") %></p>
    </div>
  <% else %>
    <p class="text-slate-600">Enter a location to load a forecast.</p>
  <% end %>
</div>
