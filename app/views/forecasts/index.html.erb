<% content_for :title, "Forecasts" %>

<div class="app">

  <!-- ─── SIDEBAR ─── -->
  <aside class="sidebar">

    <div class="search-bar">
      <span class="thermo">🌡</span>
      <span>Oklahoma City, USA</span>
      <span class="search-icon">⌕</span>
    </div>

    <div>
      <div class="city-info">
        <h3>Oklahoma City</h3>
        <p>The air quality is generally acceptable for most individuals. However, sensitive groups may experience minor to moderate symptoms from long-term exposure.</p>
      </div>

      <div class="ownership">
        <span>©</span><%= Date.today.year %> |
        <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ">Anthony Lombardi</a>
      </div>
    </div>

  </aside>

  <!-- ─── MAIN PANEL ─── -->
  <main class="main w-100vw">

    <!-- Top bar -->
    <div class="top-bar">
      <div class="brand">The<br>Forecast</div>
    </div>

    <!-- Forecast content -->
    <div class="forecast-header">
      <div class="forecast-title">Storm<br>with Heavy Rain</div>

      <div class="forecast-meta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 12c0-5 3.5-9 9-9s9 4 9 9-4 9-9 9"/>
          <path d="M3 12h4M17 12h4M12 3v4M12 17v4"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        USA, Friday, Jan 3, 2023, 8:45AM
      </div>

      <div class="forecast-desc">
        <div class="big-temp">17°</div>
        <div class="desc-text">
          Variable clouds with snow showers. High 11F. Winds E at 10 to 20 mph. Chance of snow 50%. Snow accumulations less than one inch.
        </div>
      </div>
    </div>

    <!-- Bottom section -->
    <div class="bottom-section w-100vw">

      <!-- Weekly highs/lows -->
      <div class="weekly-forecast flex flex-row justify-between">
        <div class="day-col"><span class="day-high">high 23.0 °C</span><span class="day-low">low 18 °C</span></div>
        <div class="day-col"><span class="day-high">high 20 °C</span><span class="day-low">low 13 °C</span></div>
        <div class="day-col"><span class="day-high">high 16 °C</span><span class="day-low">low 13 °C</span></div>
        <div class="day-col"><span class="day-high">high 14 °C</span><span class="day-low">low 10 °C</span></div>
        <div class="day-col"><span class="day-high">high 11 °C</span><span class="day-low">low -4 °C</span></div>
        <div class="day-col"><span class="day-high">high -8 °C</span><span class="day-low">low -12 °C</span></div>
        <div class="day-col"><span class="day-high">high -9 °C</span><span class="day-low">low -12 °C</span></div>
      </div>

      <!-- Wave chart -->
      <div class="wave-chart">
        <svg viewBox="0 0 900 55" preserveAspectRatio="none">
          <defs>
            <linearGradient id="waveGrad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#e8a832"/>
              <stop offset="65%" stop-color="#e8a832"/>
              <stop offset="85%" stop-color="#e05c2a"/>
              <stop offset="100%" stop-color="#c0392b"/>
            </linearGradient>
          </defs>
          <path d="M0,20 C60,10 100,30 180,25 C250,20 300,35 380,28 C450,22 510,32 580,27 C650,22 700,38 760,42 C810,46 860,50 900,52"
                fill="none" stroke="url(#waveGrad)" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>

      <!-- City temperatures -->
      <div class="city-row">
        <div class="city-item">
          <span class="city-temp">20°</span>
          <span class="city-name">Washington D.C</span>
          <div class="city-bar" style="background: linear-gradient(90deg,#6bcf7f,#e8a832);"></div>
        </div>
        <div class="city-item">
          <span class="city-temp">17°</span>
          <span class="city-name">Oklahoma City</span>
          <div class="city-bar" style="background: linear-gradient(90deg,#6bcf7f,#e8c832);"></div>
        </div>
        <div class="city-item">
          <span class="city-temp">14°</span>
          <span class="city-name">Philadelphia</span>
          <div class="city-bar" style="background: linear-gradient(90deg,#e8a832,#e07832);"></div>
        </div>
        <div class="city-item">
          <span class="city-temp">12°</span>
          <span class="city-name">San Francisco</span>
          <div class="city-bar" style="background: linear-gradient(90deg,#e8a832,#e05c2a);"></div>
        </div>
        <div class="city-item">
          <span class="city-temp">10°</span>
          <span class="city-name">New York City</span>
          <div class="city-bar" style="background: linear-gradient(90deg,#e05c2a,#c0392b);"></div>
        </div>
        <div class="city-item">
          <span class="city-temp">-8°</span>
          <span class="city-name">South Dakota</span>
          <div class="city-bar" style="background: linear-gradient(90deg,#c0392b,#8b1a1a);"></div>
        </div>
        <div class="city-item">
          <span class="city-temp">-9°</span>
          <span class="city-name">North Dakota</span>
          <div class="city-bar" style="background: linear-gradient(90deg,#c0392b,#7a1010);"></div>
        </div>
      </div>

    </div>

  </main>
</div>
