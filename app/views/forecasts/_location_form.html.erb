<div id="location_form" class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
  <%= form_with url: update_forecast_forecasts_path, method: :patch, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :location, class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :location, value: params[:location], class: "block w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>

    <div>
      <%= form.label :postal_code, "ZIP code", class: "mb-1 block text-sm font-medium text-slate-700" %>
      <%= form.text_field :postal_code, value: params[:postal_code], class: "block w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>

    <%= form.submit "Get forecast", class: "rounded-md bg-slate-900 px-4 py-2 font-medium text-white" %>
  <% end %>
</div>
