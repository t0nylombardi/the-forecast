<section class="forecast-hero">
  <div class="forecast-top-bar">
    <div class="forecast-brand">The<br>Forecast</div>
  </div>

  <div class="forecast-hero__body">
    <h1 class="forecast-hero__title"><%= hero.title %></h1>
    <p class="forecast-hero__meta"><%= hero.timestamp %></p>

    <div class="forecast-hero__description">
      <p class="forecast-hero__temperature"><%= hero.temperature %></p>
      <p class="forecast-hero__text"><%= hero.description %></p>
    </div>
  </div>
</section>
